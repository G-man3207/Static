{
  "manifest_version": 3,
  "name": "Static",
  "version": "2.0.10",
  "description": "Blocks extension-enumeration probes and extension-derived browser fingerprinting.",
  "permissions": ["declarativeNetRequest", "storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Static",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "fingerprint_vendors",
        "enabled": true,
        "path": "rules/fingerprint_vendors.json"
      },
      {
        "id": "captcha_vendors",
        "enabled": false,
        "path": "rules/captcha_vendors.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "block_adaptive.js",
        "block.js",
        "block_vectors.js",
        "block_iframe_attrs.js",
        "block_style_vectors.js",
        "block_fingerprint.js",
        "block_replay.js",
        "block_element_decoys.js",
        "block_globals.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lists.js", "bridge.js", "dom_scrubber.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ]
}
