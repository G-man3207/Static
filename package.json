{
  "name": "static",
  "version": "2.0.1",
  "description": "Chrome MV3 extension that blocks extension-enumeration probes and known fingerprinting telemetry.",
  "private": true,
  "scripts": {
    "test": "npm run test:static && npm run test:e2e",
    "test:static": "playwright test tests/static-validation.spec.js",
    "test:e2e": "playwright test tests/extension-behavior.spec.js",
    "test:e2e:xvfb": "xvfb-run -a npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/G-man3207/Static.git"
  },
  "keywords": [
    "chrome-extension",
    "anti-fingerprinting",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/G-man3207/Static/issues"
  },
  "homepage": "https://github.com/G-man3207/Static#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
